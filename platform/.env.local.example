# Anthropic Claude API — obrigatório para geração de conteúdo
# Crie em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Replicate API — opcional, necessário apenas para gerar imagens com Flux
# Crie em: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token_here
